    "expo-media-library": "^56.0.6",
    "expo-router": "^56.2.8",
    "expo-sharing": "^56.0.15",
    "expo-sqlite": "^56.0.4",
    "expo-status-bar": "~56.0.4",
    "nativewind": "^4.2.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "^3.0.0",
    "react-native-reanimated": "^4.4.1",
