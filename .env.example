# Meet AI — Supabase configuration
# Copy to .env.local and fill in your values from the Supabase dashboard

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Your team's web portal domain (used for invite links)
EXPO_PUBLIC_APP_DOMAIN=https://your-domain.com
